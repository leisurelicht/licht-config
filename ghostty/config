# 字体
font-family = JetBrainsMonoNerdFont
font-size = 14
font-thicken = true
adjust-cell-height = 2

# 主题
theme = light:Catppuccin Mocha,dark:Catppuccin Mocha

# 窗口
background-opacity = 0.9
background-blur-radius = 20
macos-titlebar-style = transparent
window-padding-x = 10
window-padding-y = 8
window-save-state = always
window-theme = auto

# 光标
cursor-style = bar
cursor-style-blink = true
cursor-opacity = 0.8

# 鼠标
mouse-hide-while-typing = true
copy-on-select = clipboard

# 链接
# macOS 下按住 Command 悬停/点击 URL 才会作为可打开链接处理
link-url = true
link-previews = true

# 下拉终端（Quake 风格）
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

# 安全
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# Shell 集成
shell-integration = detect

# 快捷键
# 标签页
keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
keybind = cmd+w=close_surface

# 分屏
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+h=goto_split:left
keybind = cmd+l=goto_split:right
keybind = cmd+k=goto_split:top
keybind = cmd+j=goto_split:bottom

# pane resize
keybind = cmd+ctrl+h=resize_split:left,10
keybind = cmd+ctrl+l=resize_split:right,10
keybind = cmd+ctrl+k=resize_split:up,5
keybind = cmd+ctrl+j=resize_split:down,5

# 全局热键：下拉终端
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# 性能
scrollback-limit = 25000000
